---
import { actions, isInputError } from "astro:actions";
import { Image } from "astro:assets";
import RootLayout from "~/layouts/RootLayout.astro";
import teamBuildingImg from "~/images/team-building-with-catch.png";

// actionResult is defined if the form was just submitted
const actionResult = Astro.getActionResult(actions.organizations);
if (actionResult) {
  const errorMessages: Array<string> | null = (() => {
    if (!actionResult.error) {
      return null;
    }

    if (isInputError(actionResult.error)) {
      const fields = actionResult.error.fields;
      return Object.keys(fields).map((field) =>
        fields[field as keyof typeof fields]!.join(", "),
      );
    }

    return [actionResult.error.message];
  })();

  const redirectUrl = new URL(Astro.url.pathname, Astro.url.origin);

  if (errorMessages) {
    errorMessages.forEach((errMsg) => {
      redirectUrl.searchParams.append("error", errMsg);
    });
  } else {
    redirectUrl.searchParams.append("success", "true");
  }

  return Astro.redirect(redirectUrl.toString());
}

const searchParams = Astro.url.searchParams;
const success = searchParams.has("success");
const errorMessages = searchParams.has("error")
  ? searchParams.getAll("error")
  : null;
---

<RootLayout title="Organizations" class="md:px-8 lg:px-16">
  <h1
    class="text-primary-purple font-serif font-bold text-5xl lg:text-6xl px-4 pt-8 pb-10 lg:pb-16 bg-shapes"
  >
    Organizations
  </h1>

  <div
    class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-10 lg:gap-16 px-4 lg:px-0 pb-16"
  >
    <!-- Image with coral blob — first on mobile, top-right on desktop -->
    <div class="lg:col-start-2 lg:row-start-1 relative pt-10">
      <div
        aria-hidden="true"
        class="absolute -z-10 top-0 left-[-20px] h-3/4 bg-coral rounded-[9999px_0_0_9999px]"
        style="width: calc(100% + 100vw);"
      >
      </div>
      <Image
        src={teamBuildingImg}
        alt="CATCh improv workshop in action"
        class="w-full rounded-lg object-cover aspect-[16/9]"
      />
    </div>

    <!-- Text content — second on mobile, left column on desktop spanning both rows -->
    <div class="lg:col-start-1 lg:row-start-1 lg:row-span-2">
      <p class="text-lg mb-4">
        Improv refers to any form of spontaneous storytelling or theater, and is
        quickly gaining recognition as a valuable tool for business training in
        developing greater mental agility, teamwork, and communication skills.
      </p>
      <p class="text-lg mb-6">
        Organizations from universities to corporations such as Google, Yahoo,
        McDonald's, and GE Healthcare have integrated improvisation into their
        training programs.
      </p>

      <ul class="list-disc pl-6 mb-10 space-y-2 text-lg">
        <li>Be a better communicator</li>
        <li>Be a better listener</li>
        <li>Develop poise under pressure</li>
        <li>Build confidence in the face of uncertainty and ambiguity</li>
        <li>Burn calories &amp; have fun</li>
      </ul>

      <h2 class="text-primary-purple font-serif font-bold text-3xl mb-6">
        Workshops
      </h2>

      <div class="flex flex-col gap-6">
        <div>
          <h3 class="font-bold text-lg mb-1">🧠 Creative Collaboration</h3>
          <p>
            Unlock your team's imagination through fast-paced games that build
            trust, sharpen listening, and spark innovative thinking together.
          </p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-1">
            💬 Communication &amp; Storytelling
          </h3>
          <p>
            Boost your team's ability to think on their feet and communicate
            clearly through interactive scene work and narrative exercises.
          </p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-1">🤝 Team Building Through Play</h3>
          <p>
            Strengthen relationships and break down silos with fun, low-stakes
            improv activities that encourage laughter, connection, and shared
            success.
          </p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-1">⚡ Agility &amp; Adaptability</h3>
          <p>
            Help your team embrace change and respond to the unexpected with
            confidence through quick-thinking challenges and dynamic group
            games.
          </p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-1">✨ Custom Workshop</h3>
          <p>
            Looking for something unique? We'll collaborate with you to design a
            tailored improv experience that aligns with your team's goals,
            culture, and event needs.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact form — last on mobile, bottom-right on desktop -->
    <div class="lg:col-start-2 lg:row-start-2">
      <h2 class="text-primary-purple font-serif font-bold text-3xl mb-1">
        We want to hear from you
      </h2>
      <p class="text-sm italic mb-6">* All fields are required</p>

      {
        errorMessages?.map((errorMsg) => (
          <p class="text-red-600 mb-4">{errorMsg}</p>
        ))
      }
      {
        success ? (
          <p class="text-green-700 font-medium mb-4">
            We have received your request. We'll be in touch soon!
          </p>
        ) : null
      }

      <form
        method="POST"
        action={actions.organizations}
        class="flex flex-col gap-4"
      >
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex flex-col gap-1 w-full">
            <label for="firstName" class="text-sm font-medium">
              First name *
            </label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              autocomplete="given-name"
              maxlength="35"
              class="border-2 border-light-purple rounded px-3 py-2 bg-white focus:outline-none focus:border-primary-purple w-full"
            />
          </div>
          <div class="flex flex-col gap-1 w-full">
            <label for="lastName" class="text-sm font-medium">
              Last name *
            </label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              autocomplete="family-name"
              maxlength="35"
              class="border-2 border-light-purple rounded px-3 py-2 bg-white focus:outline-none focus:border-primary-purple w-full"
            />
          </div>
        </div>

        <div class="flex flex-col gap-1">
          <label for="organizationName" class="text-sm font-medium">
            Organization name *
          </label>
          <input
            type="text"
            id="organizationName"
            name="organizationName"
            required
            autocomplete="organization"
            maxlength="100"
            class="border-2 border-light-purple rounded px-3 py-2 bg-white focus:outline-none focus:border-primary-purple w-full"
          />
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex flex-col gap-1 w-full">
            <label for="phone" class="text-sm font-medium">
              Phone number *
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              minlength="10"
              maxlength="14"
              placeholder="(555) 555-5555"
              class="border-2 border-light-purple rounded px-3 py-2 bg-white focus:outline-none focus:border-primary-purple w-full"
            />
          </div>
          <div class="flex flex-col gap-1 w-full">
            <label for="email" class="text-sm font-medium">
              Email address *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              maxlength="254"
              class="border-2 border-light-purple rounded px-3 py-2 bg-white focus:outline-none focus:border-primary-purple w-full"
            />
          </div>
        </div>

        <div class="flex flex-col gap-1">
          <label for="message" class="text-sm font-medium">
            How can we support your organization? *
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            maxlength="2000"
            class="border-2 border-light-purple rounded px-3 py-2 bg-white focus:outline-none focus:border-primary-purple resize-y"
          ></textarea>
          <p class="text-sm text-gray-600">Maximum 2,000 characters.</p>
        </div>

        <button
          type="submit"
          class="w-full bg-coral text-peach font-bold py-3 px-6 rounded hover:bg-[#B7433C] transition-colors mt-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Submit
        </button>
      </form>

      <script>
        const phoneInput = document.getElementById("phone") as HTMLInputElement;
        phoneInput.addEventListener("input", () => {
          const digits = phoneInput.value.replace(/\D/g, "").slice(0, 10);
          if (digits.length <= 3) {
            phoneInput.value = digits.length ? `(${digits}` : "";
          } else if (digits.length <= 6) {
            phoneInput.value = `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
          } else {
            phoneInput.value = `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
          }
        });
      </script>
    </div>
  </div>
</RootLayout>
