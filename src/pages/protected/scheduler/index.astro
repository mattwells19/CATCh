---
import type { User } from "@supabase/supabase-js";
import {
  addMonths,
  format,
  formatISO,
  isMatch,
  isSameMonth,
  parseISO,
  setDate,
  subMonths,
} from "date-fns";
import { supabaseScheduler } from "~/lib/supabase/scheduler";
import InternalLayout from "~/layouts/InternalLayout.astro";
import { getNow } from "~/utils/getNow";
import { Calendar } from "./_components/Calendar.tsx";
import { Header } from "./_components/Header";

import "./_styles/common.css";

const user = Astro.locals.user as User;

const fromDateParam = Astro.url.searchParams.get("from");

if (fromDateParam && !isMatch(fromDateParam, "yyyy-MM-dd")) {
  return Astro.redirect("/protected/scheduler");
}

const now = getNow();

const fromDate: Date = (() => {
  const startDate = fromDateParam ? parseISO(fromDateParam) : null;
  if (startDate) {
    return startDate;
  } else {
    return setDate(now, 1);
  }
})();

const toDate = setDate(addMonths(fromDate, 1), 1);

const monthEvents = await supabaseScheduler
  .from("events")
  .select("*")
  .gt("start", formatISO(fromDate))
  .lt("start", formatISO(toDate));

console.log(user);

const prevMonth: Date | null = (() => {
  const lastMonth = subMonths(fromDate, 1);
  if (lastMonth < now) {
    return null;
  } else {
    return lastMonth;
  }
})();

const prevMonthHref: URL = (() => {
  const destinationUrl = new URL(Astro.url);
  if (prevMonth) {
    destinationUrl.searchParams.set("from", format(prevMonth, "yyyy-MM-dd"));
  } else {
    destinationUrl.searchParams.delete("from");
  }
  return destinationUrl;
})();

const nextMonth = addMonths(fromDate, 1);
const nextMonthHref: URL = (() => {
  const destinationUrl = new URL(Astro.url);
  destinationUrl.searchParams.set("from", format(nextMonth, "yyyy-MM-dd"));
  return destinationUrl;
})();
---

<InternalLayout title="Scheduler">
  <Header
    client:load
    userName={user.user_metadata.custom_claims.global_name}
    currentMonth={format(fromDate, "MMMM")}
    prevMonthHref={isSameMonth(fromDate, now) ? null : prevMonthHref}
    nextMonthHref={nextMonthHref}
  />

  <Calendar
    client:load
    visibleMonth={fromDate.getMonth()}
    visibleYear={fromDate.getFullYear()}
    events={monthEvents.data ?? []}
  />
</InternalLayout>
